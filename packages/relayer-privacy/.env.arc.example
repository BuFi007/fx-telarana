# ASP postman config — Arc Testnet (chainId 5042002).
# Copy to `.env.arc` and fill in PRIVATE_KEY before running.
#
#   bun run asp-postman --env-file=.env.arc
#
# Single-writer constraint: do NOT point a second postman at this same
# DB_PATH or this same RPC + ENTRYPOINT pair. See README.md.

RPC_URL=https://rpc.drpc.testnet.arc.network

# C2b: deployer EOA holds ASP_POSTMAN until rotation (deferred).
# Reuses DEPLOYER_PRIVATE_KEY — copy it here once for local runs.
PRIVATE_KEY=0x

# FxPrivacyEntrypoint UUPS proxy on Arc.
ENTRYPOINT_ADDRESS=0xD11cDdd1f04e850d3810a71608A49907c80f2736

# Backfill from the FxPrivacyEntrypoint proxy deploy block.
# Verified: tx 0x833b8e08...8fd1f2 was mined in block 0x290902b (43028523).
FROM_BLOCK=43028523

POLL_INTERVAL_SECONDS=30
FINALITY_CONFIRMATIONS=5
MAX_RANGE_PER_CALL=5000
MAX_CONSECUTIVE_PUBLISH_FAILURES=0

# Per-chain DB so a single host can run both postmen without collision.
DB_PATH=./.relayer-state/postman-arc.db

DRY_RUN=false
