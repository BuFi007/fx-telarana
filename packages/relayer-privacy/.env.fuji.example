# ASP postman config — Avalanche Fuji (chainId 43113).
# Copy to `.env.fuji` and fill in PRIVATE_KEY before running.
#
#   bun run asp-postman --env-file=.env.fuji
#
# Single-writer constraint: do NOT point a second postman at this same
# DB_PATH or this same RPC + ENTRYPOINT pair. See README.md.

RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# C2b: deployer EOA holds ASP_POSTMAN until rotation (deferred).
# Reuses DEPLOYER_PRIVATE_KEY — copy it here once for local runs.
PRIVATE_KEY=0x

# FxPrivacyEntrypoint UUPS proxy on Fuji.
ENTRYPOINT_ADDRESS=0x6d5e3D5bE0Be2B29D48EDa2FA35Fa8d787D3C953

# Backfill from the FxPrivacyEntrypoint proxy deploy block.
# Verified: tx 0x966882e4...ea0aa was mined in block 0x34f511f (55529759).
FROM_BLOCK=55529759

POLL_INTERVAL_SECONDS=30
FINALITY_CONFIRMATIONS=5
# Avalanche Fuji's public RPC caps eth_getLogs at 2048 blocks per call.
# Larger ranges (e.g. 5000) return InvalidInputRpcError "requested too
# many blocks". 2000 stays safely under the ceiling.
MAX_RANGE_PER_CALL=2000
MAX_CONSECUTIVE_PUBLISH_FAILURES=0

# Per-chain DB so a single host can run both postmen without collision.
DB_PATH=./.relayer-state/postman-fuji.db

DRY_RUN=false
