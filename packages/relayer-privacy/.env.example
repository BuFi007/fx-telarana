# ASP postman config — testnet only.
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Postman account — must hold the ASP_POSTMAN role on the FxPrivacyEntrypoint.
PRIVATE_KEY=0x

# FxPrivacyEntrypoint UUPS proxy address on the target chain.
ENTRYPOINT_ADDRESS=0x

# How often to flush the current Merkle root on-chain (seconds).
POLL_INTERVAL_SECONDS=30

# Block to backfill from on startup. 0 = genesis; set to the FxPrivacyEntrypoint
# deploy block to keep startup latency reasonable on long-lived testnets.
FROM_BLOCK=0

# Set true to log without broadcasting.
DRY_RUN=false
