{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "types": ["bun"],
    "paths": {
      "@bu/fx-engine/privacy": ["../sdk/src/privacy/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
