{
  "name": "fx-telarana",
  "version": "0.1.0",
  "description": "Forex Telaraña Protocol — decentralized cross-currency money market and FX engine on Arc",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "sdk:build": "cd packages/sdk && bun run build",
    "sdk:test": "cd packages/sdk && bun test",
    "sdk:abis:sync": "cd packages/sdk && bun run abis:sync",
    "privacy-prover:build": "cd packages/privacy-prover && bun run build",
    "privacy-prover:test":  "cd packages/privacy-prover && bun test",
    "relayer-privacy:test": "cd packages/relayer-privacy && bun test",
    "build:all":   "bun run sdk:build && bun run privacy-prover:build",
    "test:all":    "bun run sdk:test && bun run privacy-prover:test && bun run relayer-privacy:test",
    "contracts:test": "cd contracts && forge build --force test/MorphoArtifacts.t.sol && forge test --no-match-contract MainnetForkTest",
    "contracts:size:guard": "cd contracts && forge build && bun ../scripts/check-eip170.ts",
    "contracts:test:fork": "cd contracts && forge build --force test/MorphoArtifacts.t.sol && ETH_RPC_URL=https://ethereum-rpc.publicnode.com forge test",
    "contracts:smoke:basket": "cd contracts && forge build --force test/MorphoArtifacts.t.sol && forge test --match-contract AvalancheBasketSmokeTest",
    "perps:arc:config:verify": "forge script contracts/script/ArcPerpConfigReadiness.s.sol:VerifyArcPerpConfig --root contracts --rpc-url ${ARC_RPC_URL:-https://rpc.drpc.testnet.arc.network} -vv",
    "perps:arc:config:export": "forge script contracts/script/ArcPerpConfigReadiness.s.sol:ExportArcPerpConfig --root contracts --rpc-url ${ARC_RPC_URL:-https://rpc.drpc.testnet.arc.network} -q",
    "perps:fuji:config:verify": "forge script contracts/script/FujiPerpConfigReadiness.s.sol:VerifyFujiPerpConfig --root contracts --rpc-url ${FUJI_RPC_URL:-https://api.avax-test.network/ext/bc/C/rpc} -vv",
    "perps:fuji:config:export": "forge script contracts/script/FujiPerpConfigReadiness.s.sol:ExportFujiPerpConfig --root contracts --rpc-url ${FUJI_RPC_URL:-https://api.avax-test.network/ext/bc/C/rpc} -q",
    "perps:arc:readiness": "cd packages/sdk && bun run perps:arc:readiness",
    "perps:arc:keeper": "cd packages/sdk && bun run perps:arc:keeper",
    "perps:arc:matcher": "cd packages/sdk && bun run perps:arc:matcher",
    "perps:arc:funding": "cd packages/sdk && bun run perps:arc:funding",
    "perps:arc:liquidations": "cd packages/sdk && bun run perps:arc:liquidations",
    "perps:arc:canary": "cd packages/sdk && bun run perps:arc:canary",
    "perps:arc:redstone-smoke": "cd packages/sdk && bun run perps:arc:redstone-smoke",
    "sdk:circle:register": "cd packages/sdk && bun scripts/register-contracts.ts",
    "api:dev": "cd apps/api && bun --hot run src/index.ts",
    "api:build": "cd apps/api && bun build src/index.ts --target=bun --outdir=dist",
    "hyperlane:arc:deploy-core": "npx @hyperlane-xyz/cli core deploy --registry https://github.com/hyperlane-xyz/hyperlane-registry --registry ./hyperlane/registry --chain arctestnet --config ./hyperlane/arc-testnet/core-config.yaml --yes",
    "hyperlane:fuji:deploy-arc-ism": "npx @hyperlane-xyz/cli ism deploy --registry https://github.com/hyperlane-xyz/hyperlane-registry --registry ./hyperlane/registry --chain fuji --config ./hyperlane/fuji/arc-testnet-trusted-relayer-ism.yaml --out ./hyperlane/fuji/arc-testnet-trusted-relayer-ism-address.json --yes",
    "hyperlane:arc:agent-config": "npx @hyperlane-xyz/cli registry agent-config --registry https://github.com/hyperlane-xyz/hyperlane-registry --registry ./hyperlane/registry --chains arctestnet fuji --out ./hyperlane/arc-testnet/agent-config.json --yes",
    "hyperlane:arc:test-dispatch": "npx @hyperlane-xyz/cli send message --registry https://github.com/hyperlane-xyz/hyperlane-registry --registry ./hyperlane/registry --origin arctestnet --destination fuji --body fx-telarana-arc-hyperlane-dispatch --quick --yes",
    "hyperlane:fuji:test-message": "npx @hyperlane-xyz/cli send message --registry https://github.com/hyperlane-xyz/hyperlane-registry --registry ./hyperlane/registry --origin fuji --destination arctestnet --body fx-telarana-fuji-to-arc-smoke --relay --yes",
    "hyperlane:bridge:mxnb": "bun scripts/hyperlane-bridge-mxnb.ts",
    "hyperlane:bridge:mxnb:full": "bun scripts/hyperlane-bridge-mxnb.ts --full",
    "hedge:arc:plan-stables": "bun scripts/plan-fx-hedge-stable-pools.ts",
    "hedge:arc:configure-stables": "forge script contracts/script/ConfigureFxHedgeStablePools.s.sol:ConfigureFxHedgeStablePools --root contracts --rpc-url ${ARC_RPC_URL:-https://rpc.drpc.testnet.arc.network} -vv",
    "hedge:arc:seed-liquidity": "forge script contracts/script/SeedFxHedgeHookLiquidity.s.sol:SeedFxHedgeHookLiquidity --root contracts --rpc-url ${ARC_RPC_URL:-https://rpc.drpc.testnet.arc.network} -vv",
    "uniswap:official-arc:check": "bun scripts/check-official-arc-v4-readiness.ts",
    "uniswap:official-arc:plan": "bun scripts/plan-official-arc-mainnet-migration.ts",
    "uniswap:official-arc:hooks:plan": "bun scripts/plan-official-arc-hook-redeploy.ts",
    "uniswap:official-arc:input:check": "bun scripts/check-official-arc-deployment-input.ts",
    "uniswap:official-arc:input:generate": "bun scripts/generate-official-arc-deployment-input.ts",
    "uniswap:official-arc:input:generate:self-test": "bun scripts/self-test-official-arc-deployment-input-generator.ts",
    "uniswap:official-arc:input:self-test": "bun scripts/self-test-official-arc-deployment-input.ts",
    "uniswap:official-arc:pools:check": "bun scripts/check-official-arc-pool-publication.ts",
    "uniswap:official-arc:pools:plan": "bun scripts/plan-official-arc-pool-publication.ts",
    "uniswap:official-arc:pools:self-test": "bun scripts/self-test-official-arc-pool-publication.ts",
    "uniswap:official-multichain:check": "bun scripts/check-official-multichain-v4-readiness.ts",
    "uniswap:official-multichain:hooks:plan": "bun scripts/plan-official-multichain-hook-redeploy.ts",
    "uniswap:official-multichain:hooks:plan:write": "bun scripts/plan-official-multichain-hook-redeploy.ts --out deployments/uniswap-v4-official-multichain-hooks-redeploy-plan.json",
    "uniswap:official-multichain:hooks:plan:check": "bun scripts/plan-official-multichain-hook-redeploy.ts --check deployments/uniswap-v4-official-multichain-hooks-redeploy-plan.json",
    "uniswap:official-multichain:input:check": "bun scripts/check-official-multichain-deployment-inputs.ts",
    "uniswap:official-multichain:input:generate": "bun scripts/generate-official-multichain-deployment-inputs.ts",
    "uniswap:official-multichain:input:generate:self-test": "bun scripts/self-test-official-multichain-deployment-input-generator.ts",
    "uniswap:official-multichain:docs:check": "bun scripts/check-official-uniswap-v4-deployments-docs.ts",
    "uniswap:official-multichain:docs:self-test": "bun scripts/self-test-official-uniswap-v4-deployments-docs.ts",
    "uniswap:official-multichain:pools:check": "bun scripts/check-official-multichain-pool-publication.ts",
    "uniswap:official-multichain:pools:plan": "bun scripts/plan-official-multichain-pool-publication.ts",
    "uniswap:official-multichain:pools:plan:write": "bun scripts/plan-official-multichain-pool-publication.ts --out deployments/uniswap-v4-official-multichain-pools-fill-plan.json",
    "uniswap:official-multichain:pools:plan:check": "bun scripts/plan-official-multichain-pool-publication.ts --check deployments/uniswap-v4-official-multichain-pools-fill-plan.json",
    "uniswap:official-multichain:pools:self-test": "bun scripts/self-test-official-multichain-pool-publication.ts",
    "uniswap:official-multichain:stateview:check": "bun scripts/check-official-multichain-stateview-readiness.ts",
    "uniswap:official-multichain:subgraph:check": "bun scripts/check-official-multichain-subgraph-readiness.ts",
    "uniswap:official-multichain:quoter:check": "bun scripts/check-official-multichain-quoter-readiness.ts",
    "uniswap:official-multichain:router:check": "bun scripts/check-official-multichain-router-readiness.ts",
    "uniswap:stateview:check": "bun scripts/check-official-arc-stateview-readiness.ts",
    "uniswap:subgraph:check": "bun scripts/check-uniswap-v4-subgraph-readiness.ts",
    "uniswap:hook-metadata:export": "bun scripts/export-uniswap-v4-hook-indexer-metadata.ts",
    "uniswap:hook-metadata:write": "bun scripts/export-uniswap-v4-hook-indexer-metadata.ts --out deployments/uniswap-v4-hook-indexer-metadata-5042002.json",
    "uniswap:hook-metadata:check": "bun scripts/export-uniswap-v4-hook-indexer-metadata.ts --check deployments/uniswap-v4-hook-indexer-metadata-5042002.json",
    "uniswap:evidence:export": "bun scripts/export-uniswap-v4-indexing-evidence.ts",
    "uniswap:evidence:write": "bun scripts/export-uniswap-v4-indexing-evidence.ts --out deployments/uniswap-v4-indexing-evidence-5042002.json",
    "uniswap:evidence:check": "bun scripts/export-uniswap-v4-indexing-evidence.ts --check deployments/uniswap-v4-indexing-evidence-5042002.json",
    "uniswap:requirements:export": "bun scripts/export-uniswap-v4-indexing-requirements.ts",
    "uniswap:requirements:write": "bun scripts/export-uniswap-v4-indexing-requirements.ts --out deployments/uniswap-v4-indexing-requirements-5042002.json",
    "uniswap:requirements:check": "bun scripts/export-uniswap-v4-indexing-requirements.ts --check deployments/uniswap-v4-indexing-requirements-5042002.json",
    "uniswap:handoff:render": "bun scripts/render-uniswap-v4-indexing-handoff.ts",
    "uniswap:handoff:write": "bun scripts/render-uniswap-v4-indexing-handoff.ts --out deployments/uniswap-v4-indexing-handoff-5042002.md",
    "uniswap:handoff:check": "bun scripts/render-uniswap-v4-indexing-handoff.ts --check deployments/uniswap-v4-indexing-handoff-5042002.md",
    "uniswap:submission:audit": "bun scripts/audit-uniswap-v4-indexing-submission.ts",
    "uniswap:completion:audit": "bun scripts/check-uniswap-v4-indexing-completion.ts",
    "uniswap:hedge:liquidity:plan": "bun scripts/plan-fx-hedge-liquidity-seeding.ts",
    "uniswap:hedge:liquidity": "bun scripts/check-fx-hedge-liquidity-readiness.ts",
    "uniswap:hedge:v4quoter": "forge test --root contracts --match-path test/FxHedgeHookV4Quoter.t.sol -vv",
    "uniswap:fxswap:v4quoter": "forge test --root contracts --match-path test/FxSwapHookV4Quoter.t.sol -vv",
    "uniswap:indexing:check": "bun scripts/check-uniswap-v4-indexing-readiness.ts",
    "uniswap:indexing:onchain": "bun scripts/verify-uniswap-v4-indexing-onchain.ts"
  },
  "devDependencies": {
    "viem": "^2.21.0"
  }
}
